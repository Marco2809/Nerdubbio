# ── API PHP (MySQL) ──────────────────────────────────────────
# Lascia vuoto in produzione (stesso dominio). In dev locale con PHP:
# VITE_API_BASE_URL=http://localhost:8080
VITE_API_BASE_URL=""

# Google Sign-In (Client ID OAuth Web — stesso usato in api/config.php)
VITE_GOOGLE_CLIENT_ID=""

# TMDB (server-side — almeno uno dei due)
# API v3: https://www.themoviedb.org/settings/api → API Key
TMDB_API_KEY=""
# API v4 (alternativa): Read Access Token
TMDB_READ_ACCESS_TOKEN=""
